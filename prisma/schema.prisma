// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  cpf           String?
  phone         String?
  accountStatus     String    @default("PENDING") // PENDING, APPROVED, REJECTED
  role              String    @default("USER")
  subscriptionStatus String   @default("FREE") // FREE, PREMIUM, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  assets        Asset[]
  financialPlan FinancialPlan?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  portfolioType   String?  // ABRIGO, RITMO, VANGUARDA, OCEANO
  saldo           Float    @default(0)
  emergencyFund   Float    @default(0)
  totalCarteira   Float    @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Asset {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ticker          String
  name            String
  category        String
  value           Float
  quantity        Float    @default(1)
  indexador       String?
  rentabilidade   Float?
  prazo           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FinancialPlan {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  desiredLifestyleCost  Float
  monthlyContribution   Float
  investmentPeriod      Int
  expectedReturn        Float    @default(12)
  currentCapital        Float?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
